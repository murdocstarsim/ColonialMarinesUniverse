cm-entrenching-start-digging = You start digging
cm-entrenching-begin-filling = You begin filling the sandbags
cm-entrenching-stop-digging = You stop digging
cm-entrenching-dismantle = You start removing the individual sandbags
cm-entrenching-start-mound = You start piling up the dirt
cm-entrenching-dismantle-mound = You start flattening the dirt mound
cm-entrenching-begin-hesco-fill = You begin packing dirt into the HESCO basket
cm-entrenching-begin-hesco-raise = You begin raising the HESCO basket higher
cm-entrenching-hesco-armed-disassemble = The HESCO basket is ready to be disassembled with an entrenching tool
cm-entrenching-begin-hesco-disassemble = You begin taking the HESCO basket apart

barricade-anchored-too-close = This is too close to the nearby {$barricade}.
